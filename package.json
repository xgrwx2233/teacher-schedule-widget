{
  "name": "teacher-schedule-widget",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --features desktop-win11 --config src-tauri/tauri.win11.conf.json",
    "tauri:dev:win10": "tauri dev --features desktop-win10 --config src-tauri/tauri.win10.conf.json",
    "tauri:dev:win11": "tauri dev --features desktop-win11 --config src-tauri/tauri.win11.conf.json",
    "tauri:build": "tauri build --features desktop-win11 --config src-tauri/tauri.win11.conf.json",
    "tauri:build:win10": "tauri build --features desktop-win10 --config src-tauri/tauri.win10.conf.json",
    "tauri:build:win11": "tauri build --features desktop-win11 --config src-tauri/tauri.win11.conf.json",
    "check:rust:win10": "cargo check --manifest-path src-tauri/Cargo.toml --no-default-features --features desktop-win10",
    "check:rust:win11": "cargo check --manifest-path src-tauri/Cargo.toml --no-default-features --features desktop-win11"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@vitejs/plugin-react": "^5.1.0",
    "aliyun-rtc-sdk": "^7.2.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3"
  }
}
